# ─────────────────────────────────────────────────────────────
# Server Status Monitor — collector config.
# Copy to  config.env  next to collector.sh (sourced by the root cron).
# ─────────────────────────────────────────────────────────────

# REQUIRED. Web account that owns the data feed. Root writes the snapshot to
# /home/<WEB_USER>/.proc_snapshot and chowns it to this user so the dashboard
# (running as this user under CageFS) can read it.
WEB_USER=myuser

# Where the collector keeps its caches (versions, disk-usage, imunify, smart).
# Default: the collector's own directory.
DATA_DIR=/root/server-status-monitor
